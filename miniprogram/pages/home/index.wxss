.hero {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 214, 153, 0.35), transparent 32%),
    linear-gradient(135deg, #3d2517, #8a5527);
  color: #fff8f0;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero-tag {
  font-size: 22rpx;
  letter-spacing: 0.32em;
  color: #f3c98d;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.15;
}

.hero-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 248, 240, 0.9);
}

.hero-notice {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 240, 0.12);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-notice-label {
  font-size: 22rpx;
  letter-spacing: 0.18em;
  color: #f3c98d;
}

.hero-notice-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #fff8f0;
}

.hero-btn {
  width: 240rpx;
  margin: 10rpx 0 0;
}

.hero-actions {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
}

.ghost-btn {
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 248, 240, 0.4);
  background: rgba(255, 248, 240, 0.08);
  color: #fff8f0;
}

.scope-list,
.entry-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.business-status {
  margin-bottom: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.business-status--open {
  background: rgba(63, 140, 92, 0.12);
}

.business-status--closed {
  background: rgba(197, 138, 58, 0.12);
}

.business-status-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2f1f14;
}

.business-status-detail {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.info-card {
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffdf8, #fff6eb);
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #8d5524;
}

.info-value {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #2f1f14;
  font-weight: 600;
}

.notice-block {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.notice-line {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.scope-item,
.entry-card {
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff;
}

.entry-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.entry-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.featured-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.featured-card {
  padding: 26rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffdf8, #fff6eb);
  box-shadow: 0 14rpx 36rpx rgba(101, 67, 33, 0.08);
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.featured-copy {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.featured-head,
.featured-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.featured-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f1f14;
}

.featured-tag,
.featured-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.featured-tag {
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
}

.featured-badge {
  background: rgba(63, 140, 92, 0.14);
  color: #2f7d4e;
}

.featured-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.featured-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #9a5a1e;
}

.featured-btn {
  width: 180rpx;
}

.featured-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.featured-sub-btn {
  width: 180rpx;
  color: #8d5524;
  border-color: rgba(141, 85, 36, 0.22);
}
