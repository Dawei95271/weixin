<view class="home-page">
  <view class="hero">
    <view class="hero-copy">
      <text class="hero-tag">HOTEL FLOOR 2 DINING</text>
      <text class="hero-title">{{projectName || '酒店二楼餐饮服务'}}</text>
      <text class="hero-desc">早餐、中餐、晚餐、包间预约、客房扫码送餐，一次放进一个小程序里。</text>
      <view class="hero-notice" wx:if="{{homeNotice}}">
        <text class="hero-notice-label">今日公告</text>
        <text class="hero-notice-text">{{homeNotice}}</text>
      </view>
      <view class="hero-actions">
        <button class="primary-btn hero-btn" bindtap="goMenu">立即点餐</button>
        <button class="ghost-btn hero-btn" bindtap="goRoomDining">客房点餐</button>
        <button class="ghost-btn hero-btn" wx:if="{{contactPhone}}" bindtap="callMerchant">联系商家</button>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">营业信息</view>
    <view class="business-status {{businessOpen ? 'business-status--open' : 'business-status--closed'}}">
      <text class="business-status-title">{{businessStatusTitle}}</text>
      <text class="business-status-detail">{{businessStatusDetail}}</text>
    </view>
    <view class="info-grid">
      <view class="info-card" wx:for="{{businessHours}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value">{{item.value}}</text>
      </view>
    </view>
    <view class="notice-block">
      <text class="notice-line">客房配送费：¥{{deliveryFee || '0'}}</text>
      <text class="notice-line">起送金额：¥{{minOrderAmount || '0'}}</text>
      <text class="notice-line" wx:if="{{roomDeliveryNotice}}">{{roomDeliveryNotice}}</text>
    </view>
  </view>

  <view class="section-card" wx:if="{{homeBanners.length}}">
    <view class="section-head">
      <view class="section-title">本周主推</view>
      <text class="section-subtitle">后台可维护的首页轮播运营位</text>
    </view>
    <swiper class="banner-swiper" indicator-dots circular autoplay interval="4200" duration="500">
      <swiper-item wx:for="{{homeBanners}}" wx:key="id">
        <view class="banner-card banner-tone-{{item.tone}}" data-banner="{{item}}" bindtap="onBannerTap">
          <text class="banner-label">HOT PICKS</text>
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle}}</text>
          <text class="banner-action">点击进入</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="section-card" wx:if="{{roomDeliveryActive}}">
    <view class="section-head">
      <view class="section-title">当前送餐房间</view>
      <button size="mini" bindtap="clearRoomDelivery">切回普通点餐</button>
    </view>
    <text class="notice-line">{{roomDeliveryTitle}}</text>
    <text class="notice-line">{{roomDeliveryDetail}}</text>
    <view class="hero-actions room-delivery-actions">
      <button class="ghost-btn hero-btn" bindtap="goRoomDining">重新识别房间</button>
      <button class="primary-btn hero-btn" bindtap="goMenu">继续点餐</button>
      <button class="ghost-btn hero-btn" bindtap="goCart">查看购物车</button>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">服务范围</view>
    <view class="scope-list">
      <view class="scope-item" wx:for="{{businessScopes}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">推荐入口</view>
    <view class="entry-grid">
      <view
        class="entry-card entry-tone-{{item.tone}}"
        wx:for="{{serviceEntries}}"
        wx:key="id"
        data-entry="{{item}}"
        bindtap="onServiceEntryTap"
      >
        <text class="entry-title">{{item.title}}</text>
        <text class="entry-desc">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <view class="section-card" wx:if="{{featuredDishes.length}}">
    <view class="section-title">今日推荐</view>
    <view class="featured-list">
      <view class="featured-card" wx:for="{{featuredDishes}}" wx:key="id">
        <view class="featured-copy">
          <view class="featured-head">
            <text class="featured-name">{{item.name}}</text>
            <text class="featured-tag" wx:if="{{item.isRecommend === 1}}">推荐</text>
          </view>
          <text class="featured-subtitle">{{item.subtitle || '酒店二楼招牌菜，适合当前时段点单'}}</text>
          <view class="featured-meta">
            <text class="featured-price">¥{{item.price}}</text>
            <text class="featured-badge" wx:if="{{item.supportsRoomDelivery === 1}}">支持客房送餐</text>
          </view>
        </view>
        <view class="featured-actions">
          <button class="ghost-btn featured-sub-btn" data-id="{{item.id}}" bindtap="openDishDetail">查看详情</button>
          <button class="primary-btn featured-btn" data-dish="{{item}}" bindtap="addFeaturedDish">加入购物车</button>
        </view>
      </view>
    </view>
  </view>
</view>
