<view class="home-page">
  <view class="hero">
    <view class="hero-copy">
      <text class="hero-tag">{{heroSettings.tag}}</text>
      <text class="hero-title">{{heroSettings.title || projectName || '酒店二楼餐饮服务'}}</text>
      <text class="hero-desc">{{heroSettings.description}}</text>
      <view class="hero-notice" wx:if="{{homeNotice}}">
        <text class="hero-notice-label">{{heroSettings.noticeLabel}}</text>
        <text class="hero-notice-text">{{homeNotice}}</text>
      </view>
      <view class="hero-actions">
        <button class="primary-btn hero-btn" bindtap="goMenu">{{heroSettings.primaryButtonText}}</button>
        <button class="ghost-btn hero-btn" bindtap="goRoomDining">{{heroSettings.secondaryButtonText}}</button>
        <button class="ghost-btn hero-btn" wx:if="{{contactPhone}}" bindtap="callMerchant">{{heroSettings.contactButtonText}}</button>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">营业信息</view>
    <view class="business-status {{businessOpen ? 'business-status--open' : 'business-status--closed'}}">
      <text class="business-status-title">{{businessStatusTitle}}</text>
      <text class="business-status-detail">{{businessStatusDetail}}</text>
    </view>
    <view class="info-grid">
      <view class="info-card" wx:for="{{businessHours}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value">{{item.value}}</text>
      </view>
    </view>
    <view class="notice-block">
      <text class="notice-line">客房配送费：¥{{deliveryFee || '0'}}</text>
      <text class="notice-line">起送金额：¥{{minOrderAmount || '0'}}</text>
      <text class="notice-line" wx:if="{{roomDeliveryNotice}}">{{roomDeliveryNotice}}</text>
    </view>
  </view>

  <view class="section-card" wx:if="{{sectionSettings.homeBanners.enabled && homeBanners.length}}">
    <view class="section-head">
      <view class="section-title">{{sectionSettings.homeBanners.title}}</view>
      <text class="section-subtitle">{{sectionSettings.homeBanners.subtitle}}</text>
    </view>
    <swiper class="banner-swiper" indicator-dots circular autoplay interval="4200" duration="500">
      <swiper-item wx:for="{{homeBanners}}" wx:key="id">
        <view class="banner-card banner-tone-{{item.tone}}" data-banner="{{item}}" bindtap="onBannerTap">
          <text class="banner-label">HOT PICKS</text>
          <text class="banner-title">{{item.title}}</text>
          <text class="banner-subtitle">{{item.subtitle}}</text>
          <text class="banner-action">{{item.actionText || '点击进入'}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="section-card" wx:if="{{roomDeliveryActive}}">
    <view class="section-head">
      <view class="section-title">当前送餐房间</view>
      <button size="mini" bindtap="clearRoomDelivery">切回普通点餐</button>
    </view>
    <text class="notice-line">{{roomDeliveryTitle}}</text>
    <text class="notice-line">{{roomDeliveryDetail}}</text>
    <view class="hero-actions room-delivery-actions">
      <button class="ghost-btn hero-btn" bindtap="goRoomDining">重新识别房间</button>
      <button class="primary-btn hero-btn" bindtap="goMenu">继续点餐</button>
      <button class="ghost-btn hero-btn" bindtap="goCart">查看购物车</button>
    </view>
  </view>

  <block wx:for="{{homeSections}}" wx:key="key">
    <view class="section-card" wx:if="{{item.key === 'businessScopes' && item.enabled}}">
      <view class="section-head">
        <view class="section-title">{{item.title}}</view>
        <text class="section-subtitle">{{item.subtitle}}</text>
      </view>
      <view class="scope-list">
        <view class="scope-item scope-tone-{{item.tone}}" wx:for="{{businessScopes}}" wx:key="id">
          <text class="scope-title">{{item.title}}</text>
          <text class="scope-desc">{{item.subtitle}}</text>
        </view>
      </view>
    </view>

    <view class="section-card" wx:if="{{item.key === 'serviceEntries' && item.enabled}}">
      <view class="section-head">
        <view class="section-title">{{item.title}}</view>
        <text class="section-subtitle">{{item.subtitle}}</text>
      </view>
      <view class="entry-grid">
        <view
          class="entry-card entry-tone-{{entry.tone}}"
          wx:for="{{serviceEntries}}"
          wx:for-item="entry"
          wx:key="id"
          data-entry="{{entry}}"
          bindtap="onServiceEntryTap"
        >
          <text class="entry-title">{{entry.title}}</text>
          <text class="entry-desc">{{entry.subtitle}}</text>
          <text class="entry-action">{{entry.actionText || '立即进入'}}</text>
        </view>
      </view>
    </view>

    <view class="section-card" wx:if="{{item.key === 'topicCards' && item.enabled && topicCards.length}}">
      <view class="section-head">
        <view class="section-title">{{item.title}}</view>
        <text class="section-subtitle">{{item.subtitle}}</text>
      </view>
      <view class="topic-grid">
        <view
          class="topic-card topic-tone-{{topic.tone}}"
          wx:for="{{topicCards}}"
          wx:for-item="topic"
          wx:key="id"
          data-topic="{{topic}}"
          bindtap="onTopicCardTap"
        >
          <text class="topic-eyebrow">{{topic.eyebrow}}</text>
          <text class="topic-title">{{topic.title}}</text>
          <text class="topic-subtitle">{{topic.subtitle}}</text>
          <text class="topic-action">{{topic.actionText || '立即查看'}}</text>
        </view>
      </view>
    </view>

    <view class="section-card" wx:if="{{item.key === 'featuredDishes' && item.enabled && featuredDishes.length}}">
      <view class="section-head">
        <view class="section-title">{{item.title}}</view>
        <text class="section-subtitle">{{item.subtitle}}</text>
      </view>
      <view class="featured-list">
        <view class="featured-card" wx:for="{{featuredDishes}}" wx:for-item="dish" wx:key="id">
          <view class="featured-copy">
            <view class="featured-head">
              <text class="featured-name">{{dish.name}}</text>
              <text class="featured-tag" wx:if="{{dish.isRecommend === 1}}">推荐</text>
            </view>
            <text class="featured-subtitle">{{dish.subtitle || '酒店二楼招牌菜，适合当前时段点单'}}</text>
            <view class="featured-meta">
              <text class="featured-price">¥{{dish.price}}</text>
              <text class="featured-badge" wx:if="{{dish.supportsRoomDelivery === 1}}">支持客房送餐</text>
            </view>
          </view>
          <view class="featured-actions">
            <button class="ghost-btn featured-sub-btn" data-id="{{dish.id}}" bindtap="openDishDetail">查看详情</button>
            <button class="primary-btn featured-btn" data-dish="{{dish}}" bindtap="addFeaturedDish">加入购物车</button>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
