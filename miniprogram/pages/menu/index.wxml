<view class="menu-page">
  <view class="menu-hero">
    <text class="menu-title">在线点餐</text>
    <text class="menu-desc">支持堂食、包间预点菜与客房扫码送餐，先选分类，再快速下单。</text>
    <view class="menu-status {{businessOpen ? 'menu-status--open' : 'menu-status--closed'}}">
      <text class="menu-status-title">{{businessStatusTitle}}</text>
      <text class="menu-status-detail">{{businessStatusDetail}}</text>
    </view>
    <view class="menu-meta">
      <text class="menu-meta-item">早餐 {{breakfastHours || '待配置'}}</text>
      <text class="menu-meta-item">中餐 {{lunchHours || '待配置'}}</text>
      <text class="menu-meta-item">晚餐 {{dinnerHours || '待配置'}}</text>
    </view>
    <view class="menu-notice">
      <text class="menu-notice-line">客房配送费 ¥{{deliveryFee || '0'}}</text>
      <text class="menu-notice-line">起送金额 ¥{{minOrderAmount || '0'}}</text>
      <text class="menu-notice-line" wx:if="{{roomDeliveryNotice}}">{{roomDeliveryNotice}}</text>
    </view>
    <view class="menu-status {{roomDeliveryActive ? 'menu-status--open' : 'menu-status--closed'}}">
      <text class="menu-status-title">{{roomDeliveryTitle}}</text>
      <text class="menu-status-detail">{{roomDeliveryDetail}}</text>
      <view class="menu-actions">
        <button class="ghost-btn detail-btn" bindtap="goRoomDining">重新识别</button>
        <button class="ghost-btn detail-btn" bindtap="goCart">查看购物车</button>
        <button class="ghost-btn detail-btn" wx:if="{{roomDeliveryActive}}" bindtap="clearRoomDelivery">切回普通点餐</button>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="category-scroll">
    <view class="category-row">
      <view
        wx:for="{{categories}}"
        wx:key="id"
        class="category-pill {{currentCategoryId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="switchCategory"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="dish-list">
    <view class="dish-card" wx:for="{{dishes}}" wx:key="id">
      <view class="dish-copy">
        <view class="dish-head">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-tag" wx:if="{{item.isRecommend === 1}}">推荐</text>
        </view>
        <text class="dish-subtitle">{{item.subtitle}}</text>
        <view class="dish-meta">
          <text class="dish-badge" wx:if="{{item.supportsRoomDelivery === 1}}">支持客房送餐</text>
          <text class="dish-badge dish-badge--muted" wx:else>仅现场/包间使用</text>
        </view>
        <text class="dish-price">¥{{item.price}}</text>
      </view>
      <view class="dish-actions">
        <button class="ghost-btn detail-btn" data-id="{{item.id}}" bindtap="openDishDetail">查看详情</button>
        <button class="primary-btn add-btn" data-dish="{{item}}" bindtap="addDish">加入购物车</button>
      </view>
    </view>
  </view>
</view>
