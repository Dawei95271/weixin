.menu-hero {
  margin: 24rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 246, 235, 0.96), rgba(255, 251, 245, 0.96));
}

.menu-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2f1f14;
}

.menu-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
}

.menu-meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.menu-meta-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(197, 138, 58, 0.1);
  color: #8d5524;
  font-size: 22rpx;
}

.menu-notice {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-notice-line {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.category-scroll {
  white-space: nowrap;
  padding: 24rpx 0 0 24rpx;
}

.category-row {
  display: flex;
  gap: 16rpx;
  padding-right: 24rpx;
}

.category-pill {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 242, 0.92);
  color: #7c5533;
}

.category-pill.active {
  background: linear-gradient(135deg, #c58a3a, #8d5524);
  color: #fff;
}

.dish-list {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.dish-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 242, 0.94);
  box-shadow: 0 16rpx 40rpx rgba(80, 53, 24, 0.08);
}

.dish-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dish-head,
.dish-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.dish-name {
  font-size: 34rpx;
  font-weight: 700;
}

.dish-tag,
.dish-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.dish-tag {
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
}

.dish-badge {
  background: rgba(63, 140, 92, 0.14);
  color: #2f7d4e;
}

.dish-badge--muted {
  background: rgba(107, 114, 128, 0.12);
  color: #6b7280;
}

.dish-subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.dish-price {
  font-size: 32rpx;
  color: #9a5a1e;
  font-weight: 600;
}

.add-btn {
  width: 180rpx;
  font-size: 26rpx;
}
