.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.reservation-summary-card {
  margin-bottom: 0;
}

.filter-panel {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-input {
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: #fff;
  font-size: 26rpx;
}

.summary-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.summary-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(141, 85, 36, 0.1);
  color: #8d5524;
  font-size: 22rpx;
}

.summary-pill--active {
  background: linear-gradient(135deg, #ca8d41, #8d5524);
  color: #fff;
}

.summary-desc {
  color: #6b7280;
  line-height: 1.7;
}

.summary-actions {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.reservation-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.reservation-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff;
}

.reservation-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.reservation-no {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.reservation-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
  font-size: 22rpx;
}

.reservation-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
}

.reservation-link {
  color: #9a5a1e;
  font-weight: 600;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.mini-btn {
  margin: 0;
  padding: 0 22rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 22rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.empty-text {
  color: #6b7280;
}

.empty-btn {
  width: 220rpx;
  margin-top: 24rpx;
}

.summary-btn {
  width: 220rpx;
  margin-top: 24rpx;
}
