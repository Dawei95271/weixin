.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.reservation-summary-card {
  margin-bottom: 0;
}

.summary-desc {
  color: #6b7280;
  line-height: 1.7;
}

.reservation-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.reservation-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff;
}

.reservation-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.reservation-no {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.reservation-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
  font-size: 22rpx;
}

.reservation-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
}

.reservation-link {
  display: block;
  margin-top: 14rpx;
  color: #9a5a1e;
  font-weight: 600;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.empty-text {
  color: #6b7280;
}

.empty-btn {
  width: 220rpx;
  margin-top: 24rpx;
}
