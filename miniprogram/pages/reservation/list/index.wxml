<view class="reservation-page">
  <view class="section-card reservation-summary-card">
    <view class="section-title">我的预约</view>
    <text class="summary-desc">当前共 {{privateRoomReservations.length + banquetReservations.length}} 条预约记录，包间与宴席统一在这里查看。</text>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-title">包间预约</view>
      <button size="mini" bindtap="goPrivateRoom">新建预约</button>
    </view>
    <view wx:if="{{privateRoomReservations.length === 0}}" class="empty-state">
      <text class="empty-text">暂时还没有包间预约记录。</text>
      <button class="primary-btn empty-btn" bindtap="goPrivateRoom">去预约包间</button>
    </view>
    <view wx:else class="reservation-list">
      <view class="reservation-item" wx:for="{{privateRoomReservations}}" wx:key="id" data-id="{{item.id}}" data-type="private-room" bindtap="goDetail">
        <view class="reservation-head">
          <text class="reservation-no">{{item.reservationNo}}</text>
          <text class="reservation-status">{{item.reservationStatusLabel}}</text>
        </view>
        <text class="reservation-meta">日期：{{item.reserveDate}}</text>
        <text class="reservation-meta">时段：{{item.timeslotLabel}}</text>
        <text class="reservation-meta">人数：{{item.guestCount}} 人</text>
        <text class="reservation-meta">定金：¥{{item.depositAmount}}</text>
        <text class="reservation-link">查看详情 ></text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view class="section-title">宴席预约</view>
      <button size="mini" bindtap="goBanquet">新建预约</button>
    </view>
    <view wx:if="{{banquetReservations.length === 0}}" class="empty-state">
      <text class="empty-text">暂时还没有宴席预约记录。</text>
      <button class="primary-btn empty-btn" bindtap="goBanquet">去预约宴席</button>
    </view>
    <view wx:else class="reservation-list">
      <view class="reservation-item" wx:for="{{banquetReservations}}" wx:key="id" data-id="{{item.id}}" data-type="banquet" bindtap="goDetail">
        <view class="reservation-head">
          <text class="reservation-no">{{item.reservationNo}}</text>
          <text class="reservation-status">{{item.statusLabel}}</text>
        </view>
        <text class="reservation-meta">类型：{{item.banquetType}}</text>
        <text class="reservation-meta">日期：{{item.reserveDate}}</text>
        <text class="reservation-meta">人数：{{item.guestCount}}</text>
        <text class="reservation-meta">预算：¥{{item.budgetAmount || 0}}</text>
        <text class="reservation-link">查看详情 ></text>
      </view>
    </view>
  </view>
</view>
