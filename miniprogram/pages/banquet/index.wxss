.summary-card {
  margin-bottom: 0;
}

.call-btn {
  margin-top: 20rpx;
}

.summary-desc,
.label,
.tip-line {
  color: #6b7280;
  line-height: 1.7;
}

.form-group {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.picker-value,
.text-input,
.text-area {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fff;
}

.text-area {
  min-height: 220rpx;
}

.summary-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff;
}

.tips-card {
  margin-bottom: 120rpx;
}

.tip-line {
  display: block;
  margin-top: 10rpx;
}

.reserve-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}
