.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.helper-text {
  display: block;
  color: #6b7280;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.service-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.service-meta-line {
  font-size: 24rpx;
  color: #8d5524;
  line-height: 1.6;
}

.room-input {
  width: 100%;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.room-btn {
  width: 100%;
}

.action-group {
  display: flex;
  gap: 16rpx;
}

.action-group .room-btn {
  flex: 1;
}

.room-result {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
