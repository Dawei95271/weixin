.summary-card {
  margin-bottom: 0;
}

.form-group {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.text-input,
.text-area {
  width: 100%;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fff;
}

.text-area {
  min-height: 160rpx;
}

.info-row,
.confirm-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.summary-desc {
  display: block;
  padding-top: 10rpx;
  color: #6b7280;
  line-height: 1.7;
}

.info-label,
.item-sub,
.item-unit,
.total-label {
  color: #6b7280;
}

.info-value,
.item-name,
.item-price {
  font-weight: 600;
}

.item-copy,
.item-amounts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-amounts {
  align-items: flex-end;
}

.total-price {
  color: #9a5a1e;
  font-weight: 700;
}

.total-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.amount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.amount-value {
  color: #4b5563;
}

.total-row {
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(139, 94, 52, 0.12);
}

.submit-btn {
  width: 100%;
}

.contact-btn {
  width: 100%;
  margin-top: 20rpx;
}
