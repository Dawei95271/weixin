<view class="confirm-page">
  <view class="section-card summary-card">
    <view class="section-title">订单确认</view>
    <view class="info-row">
      <text class="info-label">下单场景</text>
      <text class="info-value">{{orderSceneLabel}}</text>
    </view>
    <view class="info-row" wx:if="{{roomNo}}">
      <text class="info-label">房号</text>
      <text class="info-value">{{roomNo}}</text>
    </view>
    <text class="summary-desc">{{sceneHint}}</text>
    <text class="summary-desc">起送金额：¥{{minOrderAmount || '0.00'}}</text>
    <text class="summary-desc">{{businessStatusTitle}}</text>
    <text class="summary-desc">{{businessStatusDetail}}</text>
    <text class="summary-desc">{{orderHint}}</text>
    <button class="ghost-btn contact-btn" wx:if="{{merchantPhone}}" bindtap="callMerchant">联系商家</button>
  </view>

  <view class="section-card" wx:if="{{orderScene === 'ROOM_DELIVERY'}}">
    <view class="section-head">
      <view class="section-title">客房送餐状态</view>
      <button size="mini" bindtap="clearRoomDelivery">切回普通点餐</button>
    </view>
    <text class="summary-desc">{{roomSummaryTitle}}</text>
    <text class="summary-desc">{{roomSummaryDetail}}</text>
    <view class="action-group">
      <button class="ghost-btn" bindtap="goRoomDelivery">重新识别房间</button>
      <button class="ghost-btn" wx:if="{{merchantPhone}}" bindtap="callMerchant">联系商家</button>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">联系人信息</view>
    <view class="form-group">
      <text class="label">联系人</text>
      <input class="text-input" value="{{contactName}}" bindinput="onNameInput" />
    </view>
    <view class="form-group">
      <text class="label">联系电话</text>
      <input class="text-input" type="number" maxlength="11" value="{{contactPhone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-group">
      <text class="label">备注</text>
      <textarea class="text-area" value="{{remark}}" bindinput="onRemarkInput"></textarea>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">菜品清单</view>
    <view class="confirm-items">
      <view class="confirm-item" wx:for="{{cart}}" wx:key="id">
        <view class="item-copy">
          <text class="item-name">{{item.name}}</text>
          <text class="item-sub">{{item.subtitle || '酒店二楼精选菜品'}} / x{{item.quantity}}</text>
        </view>
        <view class="item-amounts">
          <text class="item-unit">单价 ¥{{item.price}}</text>
          <text class="item-price">¥{{item.lineTotal}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card total-card">
    <view class="amount-row">
      <text class="total-label">菜品金额</text>
      <text class="amount-value">¥{{itemTotalAmount}}</text>
    </view>
    <view class="amount-row">
      <text class="total-label">配送费</text>
      <text class="amount-value">¥{{deliveryFee}}</text>
    </view>
    <view class="amount-row">
      <text class="total-label">起送门槛</text>
      <text class="amount-value">¥{{minOrderAmount || '0.00'}}</text>
    </view>
    <view class="amount-row total-row">
      <text class="total-label">应付金额</text>
      <text class="total-price">¥{{totalAmount}}</text>
    </view>
    <button class="primary-btn submit-btn" loading="{{submitting}}" disabled="{{!businessCanOrder}}" bindtap="submitOrder">确认提交</button>
  </view>
</view>
