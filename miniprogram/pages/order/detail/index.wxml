<view wx:if="{{order}}" class="order-detail-page">
  <view class="section-card summary-card">
    <view class="section-head">
      <view class="section-title">订单详情</view>
      <text class="status-tag">{{order.orderStatusLabel}}</text>
    </view>
    <text class="summary-no">{{order.orderNo}}</text>
    <text class="summary-desc">下单场景：{{order.orderSceneLabel}}</text>
  </view>

  <view class="section-card">
    <view class="section-title">基础信息</view>
    <view class="detail-grid">
      <view class="detail-item">
        <text class="detail-label">联系人</text>
        <text class="detail-value">{{order.contactName || '未填写'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">联系电话</text>
        <text class="detail-value">{{order.contactPhone || '未填写'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">房号</text>
        <text class="detail-value">{{order.roomNo || '无'}}</text>
      </view>
      <view class="detail-item">
        <text class="detail-label">备注</text>
        <text class="detail-value">{{order.remark || '无'}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">金额信息</view>
    <view class="amount-list">
      <view class="amount-row">
        <text>菜品金额</text>
        <text>¥{{order.itemTotalAmount || 0}}</text>
      </view>
      <view class="amount-row">
        <text>配送费</text>
        <text>¥{{order.deliveryFee || 0}}</text>
      </view>
      <view class="amount-row amount-row--highlight">
        <text>应付金额</text>
        <text>¥{{order.payableAmount || 0}}</text>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title">菜品明细</view>
    <view class="item-list">
      <view class="item-row" wx:for="{{order.items}}" wx:key="dishId">
        <view class="item-copy">
          <text class="item-name">{{item.dishName}}</text>
          <text class="item-sub">数量 x{{item.quantity}}</text>
        </view>
        <view class="item-amounts">
          <text class="item-unit">单价 ¥{{item.unitPrice}}</text>
          <text class="item-price">¥{{item.totalPrice}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
