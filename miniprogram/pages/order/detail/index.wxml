<view wx:if="{{order}}" class="order-detail-page">
  <view class="section-card">
    <view class="section-title">订单信息</view>
    <text class="detail-line">订单号：{{order.orderNo}}</text>
    <text class="detail-line">场景：{{order.orderScene}}</text>
    <text class="detail-line">状态：{{order.orderStatus}}</text>
    <text class="detail-line">联系人：{{order.contactName}}</text>
    <text class="detail-line">联系电话：{{order.contactPhone}}</text>
    <text class="detail-line">房号：{{order.roomNo || '无'}}</text>
    <text class="detail-line">金额：¥{{order.payableAmount}}</text>
  </view>

  <view class="section-card">
    <view class="section-title">菜品明细</view>
    <view class="item-list">
      <view class="item-row" wx:for="{{order.items}}" wx:key="dishId">
        <view>
          <text class="item-name">{{item.dishName}}</text>
          <text class="item-sub">x{{item.quantity}}</text>
        </view>
        <text class="item-price">¥{{item.totalPrice}}</text>
      </view>
    </view>
  </view>
</view>
