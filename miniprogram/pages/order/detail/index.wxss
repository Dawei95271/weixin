.detail-line {
  display: block;
  margin-top: 12rpx;
  color: #4b5563;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(139, 94, 52, 0.1);
}

.item-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.item-sub {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
}

.item-price {
  color: #9a5a1e;
  font-weight: 700;
}
