.order-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.order-summary-card {
  margin-bottom: 0;
}

.summary-desc {
  color: #6b7280;
  line-height: 1.7;
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.order-no {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
  font-size: 22rpx;
}

.order-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
}

.order-link {
  display: block;
  margin-top: 18rpx;
  color: #9a5a1e;
  font-weight: 600;
}

.empty-text {
  color: #6b7280;
}

.empty-btn {
  width: 220rpx;
  margin-top: 24rpx;
}
