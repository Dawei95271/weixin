.order-list {
  display: flex;
  flex-direction: column;
}

.order-no {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.order-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
}

.order-link {
  display: block;
  margin-top: 18rpx;
  color: #9a5a1e;
  font-weight: 600;
}

.empty-text {
  color: #6b7280;
}
