<view class="order-list-page">
  <view wx:if="{{orders.length === 0}}" class="section-card">
    <view class="section-title">我的订单</view>
    <text class="empty-text">你还没有订单，先去挑几道菜吧。</text>
  </view>

  <view wx:else class="order-list">
    <view class="order-card section-card" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <text class="order-no">{{item.orderNo}}</text>
      <text class="order-meta">场景：{{item.orderScene}}</text>
      <text class="order-meta">状态：{{item.orderStatus}}</text>
      <text class="order-meta">金额：¥{{item.payableAmount}}</text>
      <text class="order-link">查看详情 ></text>
    </view>
  </view>
</view>
