<view wx:if="{{dish}}" class="dish-detail-page">
  <view class="hero-card">
    <view class="hero-head">
      <view class="hero-copy">
        <text class="hero-title">{{dish.name}}</text>
        <text class="hero-subtitle">{{dish.subtitle || '酒店二楼招牌菜，适合堂食与预约场景。'}}</text>
      </view>
      <view class="hero-tags">
        <text class="hero-tag" wx:if="{{dish.isRecommend === 1}}">推荐</text>
        <text class="hero-tag hero-tag--room" wx:if="{{dish.supportsRoomDelivery === 1}}">支持客房送餐</text>
      </view>
    </view>
    <view class="business-status {{businessOpen ? 'business-status--open' : 'business-status--closed'}}">
      <text class="business-status-title">{{businessStatusTitle}}</text>
      <text class="business-status-detail">{{businessStatusDetail}}</text>
    </view>
    <text class="hero-price">¥{{dish.price}}</text>
  </view>

  <view class="section-card">
    <view class="section-title">菜品介绍</view>
    <text class="section-desc">{{dish.description || '这道菜当前还没有补充详细介绍，欢迎联系商家了解今日做法与推荐搭配。'}}</text>
  </view>

  <view class="section-card">
    <view class="section-title">点餐提示</view>
    <view class="tip-list">
      <text class="tip-line">客房配送费：¥{{deliveryFee || '0.00'}}</text>
      <text class="tip-line">起送金额：¥{{minOrderAmount || '0.00'}}</text>
      <text class="tip-line">{{roomDeliveryNotice || '如需送至客房，请先完成房间识别后再下单。'}}</text>
    </view>
    <button class="ghost-btn call-btn" wx:if="{{merchantPhone}}" bindtap="callMerchant">联系商家</button>
  </view>

  <view class="section-card">
    <view class="section-title">加入购物车</view>
    <view class="quantity-row">
      <text class="quantity-label">数量</text>
      <view class="quantity-box">
        <button class="quantity-btn" bindtap="decreaseQuantity">-</button>
        <text class="quantity-value">{{quantity}}</text>
        <button class="quantity-btn" bindtap="increaseQuantity">+</button>
      </view>
    </view>
    <view class="action-row">
      <button class="ghost-btn action-btn" bindtap="goCart">去购物车</button>
      <button class="primary-btn action-btn" bindtap="addCurrentDish">加入购物车</button>
    </view>
  </view>
</view>
