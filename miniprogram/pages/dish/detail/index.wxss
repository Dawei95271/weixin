.dish-detail-page {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 248, 238, 0.98), rgba(255, 253, 248, 0.98));
  box-shadow: 0 18rpx 46rpx rgba(80, 53, 24, 0.08);
}

.hero-head,
.hero-copy,
.hero-tags,
.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2f1f14;
}

.hero-subtitle,
.section-desc,
.tip-line,
.business-status-detail {
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
}

.hero-tags {
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.hero-tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(213, 140, 53, 0.16);
  color: #a35d1f;
  font-size: 22rpx;
}

.hero-tag--room {
  background: rgba(63, 140, 92, 0.14);
  color: #2f7d4e;
}

.business-status {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.business-status--open {
  background: rgba(63, 140, 92, 0.12);
}

.business-status--closed {
  background: rgba(197, 138, 58, 0.12);
}

.business-status-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #2f1f14;
}

.hero-price {
  display: block;
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #9a5a1e;
}

.quantity-row,
.quantity-box,
.action-row {
  display: flex;
  align-items: center;
}

.quantity-row {
  justify-content: space-between;
  gap: 18rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #2f1f14;
  font-weight: 600;
}

.quantity-box {
  gap: 18rpx;
}

.quantity-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  border: 0;
  background: rgba(141, 85, 36, 0.12);
  color: #8d5524;
  font-size: 34rpx;
}

.quantity-value {
  min-width: 44rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f1f14;
}

.call-btn {
  margin-top: 20rpx;
}

.action-row {
  margin-top: 28rpx;
  gap: 18rpx;
}

.action-btn {
  flex: 1;
}
