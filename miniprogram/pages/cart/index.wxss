.cart-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(139, 94, 52, 0.1);
}

.cart-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.cart-price {
  display: block;
  margin-top: 8rpx;
  color: #9a5a1e;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.empty-state {
  color: #6b7280;
  line-height: 1.7;
}

.total-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.total-label {
  color: #6b7280;
}

.total-price {
  font-size: 52rpx;
  font-weight: 700;
  color: #8d5524;
}

.action-group {
  display: flex;
  gap: 16rpx;
}

.action-group button {
  flex: 1;
}
