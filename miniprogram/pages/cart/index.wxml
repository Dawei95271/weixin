<view class="cart-page">
  <view wx:if="{{roomInfo}}" class="section-card delivery-card">
    <view class="section-head">
      <view class="section-title">当前为客房送餐</view>
      <button size="mini" bindtap="clearRoomDelivery">切回普通点餐</button>
    </view>
    <text class="delivery-desc">已识别房间 {{roomInfo.roomNo}}，提交订单后会按客房送餐场景处理。</text>
    <text class="delivery-desc" wx:if="{{roomDeliveryNotice}}">{{roomDeliveryNotice}}</text>
  </view>

  <view class="section-card">
    <view class="section-title">已选菜品</view>
    <view wx:if="{{cart.length === 0}}" class="empty-wrapper">
      <text class="empty-state">购物车还是空的，先去点几个菜吧。</text>
      <button class="primary-btn empty-btn" bindtap="goMenu">去点餐</button>
    </view>
    <view wx:else class="cart-list">
      <view class="cart-item" wx:for="{{cart}}" wx:key="id">
        <view class="cart-copy">
          <text class="cart-name">{{item.name}}</text>
          <text class="cart-sub">{{item.subtitle || '酒店二楼精选菜品'}}</text>
          <text class="cart-price">¥{{item.price}}</text>
        </view>
        <view class="stepper">
          <button size="mini" data-id="{{item.id}}" bindtap="decrease">-</button>
          <text>{{item.quantity}}</text>
          <button size="mini" data-id="{{item.id}}" bindtap="increase">+</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card total-card">
    <text class="summary-line">共 {{totalCount}} 份菜品，{{summaryText}}</text>
    <text class="summary-line">起送金额 ¥{{minOrderAmount || '0.00'}}，当前配送费 ¥{{roomInfo ? deliveryFee : '0.00'}}</text>
    <text class="total-label">合计</text>
    <text class="total-price">¥{{totalAmount}}</text>
    <view class="action-group">
      <button bindtap="clearAll">清空购物车</button>
      <button class="primary-btn" bindtap="submitOrder">提交订单</button>
    </view>
    <button class="ghost-btn contact-btn" wx:if="{{contactPhone}}" bindtap="callMerchant">联系商家</button>
  </view>
</view>
