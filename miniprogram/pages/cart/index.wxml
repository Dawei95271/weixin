<view class="cart-page">
  <view class="section-card">
    <view class="section-title">已选菜品</view>
    <view wx:if="{{cart.length === 0}}" class="empty-state">购物车还是空的，先去点几个菜吧。</view>
    <view wx:else class="cart-list">
      <view class="cart-item" wx:for="{{cart}}" wx:key="id">
        <view>
          <text class="cart-name">{{item.name}}</text>
          <text class="cart-price">¥{{item.price}}</text>
        </view>
        <view class="stepper">
          <button size="mini" data-id="{{item.id}}" bindtap="decrease">-</button>
          <text>{{item.quantity}}</text>
          <button size="mini" data-id="{{item.id}}" bindtap="increase">+</button>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card total-card">
    <text class="total-label">合计</text>
    <text class="total-price">¥{{totalAmount}}</text>
    <view class="action-group">
      <button bindtap="clearAll">清空购物车</button>
      <button class="primary-btn" bindtap="submitOrder">提交订单</button>
    </view>
  </view>
</view>
